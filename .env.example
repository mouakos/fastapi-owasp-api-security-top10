# =============================================================================
# .env.example — copy to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# =============================================================================


# =============================================================================
# REQUIRED — must be set in every environment, no safe default exists
# =============================================================================

# Secret key for JWT token signing. Must be a long, random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Database connection URL.
# Development:  DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Production:   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbnameb
DATABASE_URL=postgresql+asyncpg://appuser:changethis@localhost:5432/appdb

# Comma-separated list of origins allowed to make cross-origin requests (CORS).
# Must match exactly the scheme+host+port of your frontend (no trailing slash).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Deployment environment. Controls docs exposure and other env-specific behaviour.
# Values: development | staging | production
ENVIRONMENT=development


# =============================================================================
# OPTIONAL — safe defaults exist but you may want to override per environment
# =============================================================================

# Log verbosity. Use DEBUG locally, INFO in staging/production.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Emit logs as JSON (useful when shipping to Datadog, ELK, Loki, etc.).
# Set to True in cloud deployments, False for local human-readable output.
LOG_SERIALIZED=False

# Write logs to a file instead of stdout.
# Containers should keep this False and let the orchestrator capture stdout.
LOG_TO_FILE=False

# =============================================================================
# BOOTSTRAP — only needed on first startup to seed the initial admin account.
# =============================================================================

FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_USERNAME=admin

# Must satisfy password policy: min 8 chars, one uppercase, one digit, one symbol, no spaces.
FIRST_ADMIN_PASSWORD=ChangeMe@1
