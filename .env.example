# This is an example .env file for the FastAPI application.
# You can copy this file to .env and modify the values as needed.
# NEVER commit your actual .env file to version control.

# Database connection URL (using SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./test.db
# Set to True to enable SQL query logging (only for development)
DATABASE_ECHO=False

# -----------------------------------------
# Logging configuration
# -----------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Log to file instead of console (True/False)
LOG_TO_FILE=False
# Set to True to log serialized logs in JSON format (useful for structured logging)
LOG_SERIALIZED=False

# -----------------------------------------
# Application settings
# -----------------------------------------
# Set the environment (development, staging, production)
ENVIRONMENT=development
# Application version
VERSION=1.0.0
# Comma-separated list of allowed CORS origins (API8)
ALLOWED_HOSTS=http://localhost:3000,http://localhost:8080


# -----------------------------------------
# Security settings
# -----------------------------------------
# Secret key for JWT token generation (use a strong, random value in production)
SECRET_KEY=your_secret_key_here
# Algorithm used for JWT token encoding
ALGORITHM=HS256
# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Audience for JWT tokens
JWT_AUDIENCE=fastapi-owasp-app
# Issuer for JWT tokens
JWT_ISSUER=fastapi-owasp-api

# --------------------------------
# Account lockout settings
# --------------------------------
# Number of minutes to lock the account after reaching max failed login attempts
LOCKOUT_MINUTES=15
# Maximum number of failed login attempts before locking the account
MAX_FAILED_ATTEMPTS=5

# --------------------------------
# Initial admin user settings (for seeding the database)
# --------------------------------
# Email for the initial admin user
FIRST_ADMIN_EMAIL=admin@example.com
# Username for the initial admin user
FIRST_ADMIN_USERNAME=admin
# Password for the initial admin user (use a strong password in production)
FIRST_ADMIN_PASSWORD=admin